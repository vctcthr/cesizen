{% extends 'base.html.twig' %}

{% block title %}Information{% endblock %}

{% block body %}
    <h1>Information</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ information.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ information.title }}</td>
            </tr>
            <tr>
                <th>Content</th>
                <td>{{ information.content }}</td>
            </tr>
            <tr>
                <th>IsActive</th>
                <td>{{ information.isActive ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>CreatedAt</th>
                <td>{{ information.createdAt ? information.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_admin_information_index') }}">back to list</a>

    <a href="{{ path('app_admin_information_edit', {'id': information.id}) }}">edit</a>

    {{ include('admin_information/_delete_form.html.twig') }}
{% endblock %}
